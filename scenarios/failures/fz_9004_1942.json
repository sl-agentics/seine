  "drl": "rule \"R0\"\nsalience -7\nagenda-group \"ga\"\nwhen\n    $p0_0 : T1($b0_0_0 : f1, $b0_0_1 : f1)\nthen\n    delete($p0_0);\nend\nrule \"R1\"\nwhen\n    T1($b1_0_0 : f0)\n    T0(f0 > 4, $b1_1_0 : f2)\nthen\n    drools.setFocus(\"ga\");\nend\nquery Q0(String $qa0_0, double $qa0_1)\n    ( $qp0_0 : T1(f1 == $qa0_0, f2 <= 100, f2 > -1) )\n    or\n    ( $qp0_1 : T1(f0 == $qa0_1, f1 > \"alpha\", f2 != 9, $qb0_0 : f2, $qb0_1 : f2) and $qp0_2 : T1(f1 != \"\", f0 >= -2.5, f2 < $qb0_1, $qb0_2 : f2) )\n    or\n    ( $qp0_3 : T1(f1 == $qa0_0, f2 != 7, f2 != -1) )\nend\n\nquery Q1(String $qa1_0, boolean $qa1_1)\n    $qp1_0 : T0(f1 == $qa1_0, f2 == $qa1_1, f2 != true, $qb1_0 : f0)\n    $qp1_1 : T0(f0 >= -1000000007, f1 < \"beta\", $qb1_1 : f0, $qb1_2 : f2)\nend\n\nquery TCr(String $a, String $b)\n    ( RelR(src == $a, dst == $b) )\n    or\n    ( RelR($m, $b;) and TCr($a, $m;) )\nend\n\nquery TWr(String $w)\n    TCr($w, $f;)\nend\n\n",
