  "drl": "rule \"R0\"\nwhen\n    T3(f1 in (true), $b0_0_0 : f1, $b0_0_1 : f0)\n    T0(f2 == true, f1 <= 0.5, $b0_1_0 : f2, $b0_1_1 : f2)\n    T1($b0_2_0 : f1)\nthen\nend\nrule \"R1\"\nagenda-group \"gb\"\nwhen\n    $p1_0 : T3(f1 in (true), $b1_0_0 : f1, $b1_0_1 : f0)\n    T0(f2 == true, f1 <= 0.5, $b1_1_0 : f2, $b1_1_1 : f2)\nthen\n    delete($p1_0);\nend\nrule \"R2\"\nsalience -10\nwhen\n    $p2_0 : T1(f1 == true, f1 == true, $b2_0_0 : f0)\nthen\n    insert(new T2($p2_0.getF0(), $p2_0.isF1()));\nend\nrule \"R3\"\nsalience($b3_0_0 * 2)\nno-loop\nwhen\n    T3($b3_0_0 : f0, $b3_0_1 : f0)\nthen\n    drools.setFocus(\"gb\");\nend\nrule \"R4\"\nsalience 3\nwhen\n    $p4_0 : T1(f0 in (-1, 4.5), $b4_0_0 : f0)\nthen\n    insert(new T3($p4_0.getF0(), false));\n    insert(new T3(0, true));\nend\nrule \"R5\"\nagenda-group \"gb\"\nwhen\n    T2($b5_0_0 : f0)\n    T0($b5_1_0 : f2, $b5_1_1 : f2)\n    T0(f2 != $b5_1_1)\nthen\n    insert(new T3(6, false));\n    insert(new T3($b5_0_0, true));\nend\nquery Q0(long $qa0_0, long $qa0_1, long $qa0_2)\n    ( $qp0_0 : T3(f0 == $qa0_0, f0 == $qa0_1, f1 != false, f1 != false) )\n    or\n    ( $qp0_1 : T2(f0 == $qa0_2, f0 > -1000000007, f1 != false, $qb0_0 : f0, $qb0_1 : f0) )\nend\n\nquery Q1(boolean $qa1_0, long $qa1_1)\n    ( $qp1_0 : T3(f1 == $qa1_0, f1 != false) and $qp1_1 : T2(f1 != false, $qb1_0 : f1, $qb1_1 : f0) )\n    or\n    ( $qp1_2 : T2(f0 == $qa1_1, f0 > -5, $qb1_2 : f1, $qb1_3 : f1) )\nend\n\nquery TCr(long $a, long $b)\n    ( RelR($a, $b;) )\n    or\n    ( RelR($m, $b;) and TCr($a, $m;) )\nend\n\nquery TWr(long $w)\n    TCr($w, $f;)\n    MarkR(node == $f)\nend\n\n",
