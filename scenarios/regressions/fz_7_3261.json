  "drl": "rule \"R0\"\nwhen\n    $p0_0 : T0(f1 not in (4.5), $b0_0_0 : f2, $b0_0_1 : f0)\nthen\n    insert(new T1(11, $b0_0_0, $p0_0.getF2(), $p0_0.isF3()));\nend\nquery Q0(double $qa0_0, boolean $qa0_1, double $qa0_2)\n    ( $qp0_0 : T0(f1 == $qa0_0, f3 == $qa0_1, f2 != -3) and $qp0_1 : T0(f1 == $qa0_2, f0 >= 0.5, $qb0_0 : f0, $qb0_1 : f2) )\n    or\n    ( $qp0_2 : T2(f0 == $qa0_1, f2 == $qa0_1, f1 != false, $qb0_2 : f0) )\n    or\n    ( $qp0_3 : T1(f3 == $qa0_1, f0 > 8, $qb0_3 : f1) and $qp0_4 : T0($qb0_4 : f3) )\nend\n\nquery Q1(double $qa1_0, double $qa1_1, boolean $qa1_2)\n    ( $qp1_0 : T0(f0 == $qa1_0, f1 == $qa1_1, f2 > -3) )\n    or\n    ( $qp1_1 : T0(f3 == $qa1_2, f1 <= -0.5, $qb1_0 : f3, $qb1_1 : f1) )\nend\n\nquery TCr(String $a, String $b)\n    ( RelR($a, $b;) )\n    or\n    ( RelR($m, $b;) and TCr($a, $m;) and MarkR(node == $m) )\nend\n\nrule QR0\nwhen\n    T1($qr0_b0 : f1)\n    ?TCr($qr0_x0, $qr0_x1;)\nthen\n    insert(new QOut(1, -1, 5.5, $qr0_x1, false));\nend\n\nrule QR1\nwhen\n    T2($qr1_b0 : f2)\n    ?Q0(3.0, $qr1_x0, 0.0;)\nthen\n    insert(new QOut(2, 4, 0.5, \"\", $qr1_x0));\nend\n\nrule QR2\nwhen\n    T2(f0 == true, $qr2_b0 : f0)\n    T0($qr2_b1 : f2)\n    ?Q0(-1.0, $qr2_x0, 2.5;)\n    ?Q0(-2.0, $qr2_x1, -3.0;)\n    T2(f0 == $qr2_x0)\nthen\n    insert(new QOut(3, $qr2_b1, -0.5, \"ab\", false));\nend\n\nrule QRtwin salience -9\nwhen\n    T2($qr1_b0 : f2)\n    ?Q0(3.0, $qr1_x0, 0.0;)\nthen\n    insert(new QOut(4, 0, 0.0, \"t\", false));\nend\n\n",
