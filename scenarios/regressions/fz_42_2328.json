  "drl": "rule \"R0\"\nwhen\n    T2(f3 == false, f1 != true, $b0_0_0 : f0, $b0_0_1 : f2)\nthen\nend\nrule \"R1\"\nsalience 2\nwhen\n    T3(f3 == false, $b1_0_0 : f1, $b1_0_1 : f3)\nthen\nend\nrule \"R2\"\nsalience -4\nno-loop\nwhen\n    not T3(f2 != false, f1 != false)\nthen\nend\nquery Q0(long $qa0_0, long $qa0_1)\n    $qp0_0 : T1(f0 == $qa0_0, f0 == $qa0_1, f0 != 100, f0 > 0)\n    $qp0_1 : T2()\nend\n\nquery Q1(String $qa1_0, long $qa1_1, boolean $qa1_2)\n    ( $qp1_0 : T0(f1 == $qa1_0, f0 == $qa1_1, f1 > \"a\", $qb1_0 : f0, $qb1_1 : f0) )\n    or\n    ( $qp1_1 : T0(f2 == $qa1_1, $qb1_2 : f1) and $qp1_2 : T1(f0 >= 7, f1 != 100, $qb1_3 : f0) )\n    or\n    ( $qp1_3 : T3(f2 == $qa1_2, f2 != false, f2 != false, $qb1_4 : f2) and $qp1_4 : T0(f0 == $qa1_1, f1 < \"b\", $qb1_5 : f2, $qb1_6 : f2) )\nend\n\nquery TCr(String $a, String $b)\n    ( RelR($a, $b;) )\n    or\n    ( RelR($m, $b;) and TCr($a, $m;) )\nend\n\nrule QR0 salience 0\nwhen\n    T0($qr0_b0 : f1)\n    ?Q1($qr0_b0, $qr0_x0, false;)\n    ?Q0($qr0_x1, $qr0_x2;)\nthen\n    insert(new QOut(1, $qr0_x2, $qr0_x0, $qr0_b0, true));\nend\n\nrule QR1\nwhen\n    ?TCr($qr1_x0, $qr1_x0;)\nthen\n    insert(new QOut(2, 9, -2.5, \"beta\", true));\nend\n\nrule QR2 salience 6\nwhen\n    ?TCr($qr2_x0, $qr2_x0;)\nthen\n    insert(new QOut(3, 5, 0.0, \"zz\", false));\nend\n\nrule QRtwin\nwhen\n    T0($qr0_b0 : f1)\n    ?Q1($qr0_b0, $qr0_x0, false;)\n    ?Q0($qr0_x1, $qr0_x2;)\nthen\n    insert(new QOut(4, 0, 0.0, \"t\", false));\nend\n\n",
