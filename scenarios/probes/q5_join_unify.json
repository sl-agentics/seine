{
  "name": "q5_join_unify",
  "types": [
    { "name": "Person", "fields": [ { "name": "name", "type": "String" }, { "name": "age", "type": "i64" } ] }
  ],
  "facts": [
    { "type": "Person", "fields": { "name": "alice", "age": 30 } },
    { "type": "Person", "fields": { "name": "bob",   "age": 30 } },
    { "type": "Person", "fields": { "name": "carol", "age": 45 } },
    { "type": "Person", "fields": { "name": "dave",  "age": 30 } }
  ],
  "drl": "query SameAge(long $x)\n    $p : Person(age == $x, $n : name)\n    $q : Person(age == $x, name != $n)\nend\n",
  "queries": [
    { "call": "SameAge", "args": [30] },
    { "call": "SameAge", "args": [null] },
    { "call": "SameAge", "args": [45] }
  ]
}
