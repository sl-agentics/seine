 "drl": "query reach(String $s, long $d)\n    ( GoalF($s;) and ZeroF($d;) )\n    or\n    ( Dec($d, $d1;) and MoveF($s, $n;) and reach($n, $d1;) )\nend\n\nrule Step1\nwhen\n    P0($s : state)\n    MoveF(src == $s, $n : dst)\n    ?reach($n, 4;)\nthen\n    insert(new P1($n));\nend\n\nrule Step2\nwhen\n    P1($s : state)\n    MoveF(src == $s, $n : dst)\n    ?reach($n, 3;)\nthen\n    insert(new P2($n));\nend\n\nrule Step3\nwhen\n    P2($s : state)\n    MoveF(src == $s, $n : dst)\n    ?reach($n, 2;)\nthen\n    insert(new P3($n));\nend\n\nrule Step4\nwhen\n    P3($s : state)\n    MoveF(src == $s, $n : dst)\n    ?reach($n, 1;)\nthen\n    insert(new P4($n));\nend\n\nrule Step5\nwhen\n    P4($s : state)\n    MoveF(src == $s, $n : dst)\n    ?reach($n, 0;)\nthen\n    insert(new P5($n));\nend\n\nrule Solved\nwhen\n    P5($s : state)\nthen\n    insert(new Solution($s));\nend\n",
