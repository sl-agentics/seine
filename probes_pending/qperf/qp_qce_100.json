 "name": "qp_qce_100",
 "drl": "rule \"R0\"\nwhen\n    $p0_0 : T0()\nthen\n    insert(new T1($p0_0.getF1()));\nend\nrule \"R3\"\nsalience -6\nwhen\n    $p3_0 : T1(f0 >= 1.5, $b3_0_0 : f0)\n    T1(f0 not in (9, -5), f0 < $b3_0_0, $b3_1_0 : f0)\nthen\n    delete($p3_0);\nend\nquery TCr(long $a, long $b)\n    ( RelR(src == $a, dst == $b) )\n    or\n    ( RelR($m, $b;) and TCr($a, $m;) and MarkR(node == $m) )\nend\n\nrule QR0 salience -8\nwhen\n    T1(f0 > -2)\n    ?TCr($qr0_x0, $qr0_x1;)\nthen\n    insert(new QOut(1, $qr0_x1, $qr0_x0, \"beta\", true));\nend\nrule QRtwin\nwhen\n    T1(f0 > -2)\n    ?TCr($qr0_x0, $qr0_x1;)\nthen\n    insert(new QOut(2, 0, 0.0, \"t\", false));\nend\n",
